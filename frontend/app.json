{
  "expo": {
    "name": "SekoPi",
    "slug": "sekopi",
    "version": "1.0.0",
    "orientation": "portrait",
    "scheme": "sekopi",
    "userInterfaceStyle": "dark",
    "web": {
      "bundler": "metro",
      "output": "static"
    },
    "platforms": ["ios", "android", "web"],
    "plugins": [
      "expo-router",
      "expo-secure-store"
    ],
    "experiments": {
      "typedRoutes": true
    }
  }
}
