{
  "expo": {
    "name": "Sekopi",
    "slug": "sekopi-mobile",
    "version": "1.0.0",
    "scheme": "sekopi",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "dark",
    "splash": {
      "backgroundColor": "#0f1117"
    },
    "ios": {
      "supportsTablet": false,
      "infoPlist": {
        "NSCameraUsageDescription": "Digunakan untuk foto absensi",
        "NSLocationWhenInUseUsageDescription": "Digunakan untuk verifikasi lokasi absensi"
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#0f1117"
      },
      "permissions": [
        "CAMERA",
        "ACCESS_FINE_LOCATION",
        "ACCESS_COARSE_LOCATION"
      ]
    },
    "plugins": [
      "expo-router",
      "expo-camera",
      "expo-location"
    ]
  }
}
