{
  "expo": {
    "name": "Sekopi",
    "slug": "sekopi-mobile",
    "version": "1.0.0",
    "scheme": "sekopi",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "dark",
    "splash": {
      "backgroundColor": "#0f1117"
    },
    "ios": {
      "supportsTablet": false
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#0f1117"
      }
    },
    "plugins": [
      "expo-router"
    ]
  }
}
